rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }

    function isValidInquiry(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() <= 50 &&
             data.purpose in ['new', 'renewal'] &&
             data.budget is string && data.budget.size() <= 50 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 2000 &&
             data.createdAt == request.time;
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidId(inquiryId) && isValidInquiry(incoming());
      // Admin only read
      allow read: if isSignedIn(); // For simplicity in this demo, signed in users can read
    }
  }
}
